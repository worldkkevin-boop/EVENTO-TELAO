# Copie este arquivo para ".env" e preencha. NUNCA suba o .env pro GitHub (tem segredos).

# Porta do servidor
PORT=4000

# Endereco publico do sistema (em producao: https://disparaja.ksstudio.cloud)
# Local pode deixar em branco (usa http://localhost:4000)
BASE_URL=

# Segredo dos logins (qualquer texto aleatorio longo)
SESSION_SECRET=troque-por-um-texto-aleatorio-bem-grande

# Seu e-mail de ADMIN (essa conta vira admin e ve o painel /admin)
ADMIN_EMAIL=worldkkevin@gmail.com

# Mercado Pago (Access Token) - comece com o de TESTE, depois troque pelo de produção
MP_ACCESS_TOKEN=

# Comtele (API nova) - a chave do DONO. Os clientes NAO veem isso; eles so tem saldo em R$.
COMTELE_API_KEY=
COMTELE_ROTA=16

# WhatsApp OFICIAL (encaixavel) - so liga quando preencher a URL abaixo.
# Enquanto vazio, o canal WhatsApp aparece como "em ativacao" e nada quebra no SMS.
# Pegue a URL/credenciais com a Comtele quando o WhatsApp Business for liberado (precisa MEI + Meta Business).
COMTELE_WHATSAPP_URL=
# Se a Comtele usar uma chave diferente pro WhatsApp, coloque aqui. Senao usa a COMTELE_API_KEY.
COMTELE_WA_API_KEY=

# Bonus de boas-vindas pra novos cadastros testarem (em centavos). 100 = R$1,00. 0 = desliga.
BONUS_CADASTRO_CENTAVOS=100
